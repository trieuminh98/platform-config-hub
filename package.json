{
  "name": "platform-config-hub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:rules-gen": "turbo run build --filter=@platform-config-hub/rules-gen",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "link:rules-gen": "pnpm -C packages/rules-gen link --global",
    "setup:rules-gen": "pnpm run build:rules-gen && pnpm run link:rules-gen"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
